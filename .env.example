# NORMIA - Variables d'environnement
# Copier ce fichier en .env.local et renseigner les valeurs

# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/normia"

# NextAuth.js
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (paiements)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stockage fichiers (S3 compatible)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@normia.fr"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NORMIA"
